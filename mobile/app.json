{
  "expo": {
    "name": "Taxi Vanille",
    "slug": "taxivanille",
    "version": "1.0.0",
    "orientation": "portrait",
    "android": {
      "package": "yt.taxivanille.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECORD_AUDIO",
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      ["expo-av", { "microphonePermission": "Autoriser l'enregistrement audio pour les incidents" }]
    ],
    "scheme": "taxivanille"
  }
}
