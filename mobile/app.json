{
  "expo": {
    "name": "Taxi Vanille",
    "slug": "taxivanille",
    "version": "1.0.0",
    "orientation": "portrait",
    "android": {
      "package": "yt.taxivanille.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-av",
        {
          "microphonePermission": "Autoriser l'enregistrement audio pour les incidents"
        }
      ]
    ],
    "scheme": "taxivanille",
    "experiments": {
      "tsconfigPaths": true,
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a7317d98-41b0-4b94-b179-49e04da666f0"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a7317d98-41b0-4b94-b179-49e04da666f0"
    },
    "ios": {}
  }
}
