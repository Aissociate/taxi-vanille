# ─────────────────────────────────────────────────────────────────────────────
# Taxi Vanille — Template de configuration
#
# Pour la PROD : copier en .env.production (déjà gitignoré) et générer les
# secrets avec :
#     openssl rand -hex 32   # JWT_SECRET et JWT_REFRESH_SECRET
#     openssl rand -hex 24   # DB_PASSWORD
#
# Pour le DEV local : copier en .env
# ─────────────────────────────────────────────────────────────────────────────

# Environnement (development | production)
NODE_ENV=production

# Base de données PostgreSQL
DB_PASSWORD=changeme_openssl_rand_hex_24

# JWT (générer avec: openssl rand -hex 32)
JWT_SECRET=change_me_openssl_rand_hex_32_caracteres_minimum
JWT_REFRESH_SECRET=change_me_refresh_openssl_rand_hex_32_minimum

# Ports exposés
HTTP_PORT=80
BACKEND_PORT=3001          # dev seulement (bind 127.0.0.1)

# URL publique de l'API
# Sur VPS avec nginx : laisser /api/v1
# Accès direct (sans nginx) : http://VPS_IP:3001/api/v1
NEXT_PUBLIC_API_URL=/api/v1

# WebSocket (vide = même origine via nginx)
NEXT_PUBLIC_WS_URL=

# Mapbox (optionnel — pour les cartes)
MAPBOX_TOKEN=

# AWS S3 (optionnel — pour les documents chauffeurs)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=taxivanille
S3_REGION=

# Firebase Cloud Messaging (optionnel — notifications push Android)
FCM_SERVER_KEY=

# CORS — origines autorisées par le backend
# Prod : https://app.taxivanille.yt
# Dev  : http://localhost:3000,http://localhost:80
ALLOWED_ORIGINS=https://app.taxivanille.yt
