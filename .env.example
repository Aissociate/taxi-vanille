# ─────────────────────────────────────────────────────────────────────────────
# Taxi Vanille — Configuration VPS
# Copier ce fichier en .env et remplir les valeurs
# ─────────────────────────────────────────────────────────────────────────────

# Base de données PostgreSQL
DB_PASSWORD=mot_de_passe_fort_ici

# JWT (générer avec: openssl rand -hex 32)
JWT_SECRET=changer_moi_32_caracteres_minimum_ici
JWT_REFRESH_SECRET=changer_moi_refresh_32_caracteres_ici

# Ports exposés (modifier si déjà utilisés)
HTTP_PORT=80
BACKEND_PORT=3001          # accès direct optionnel (debug)

# URL publique de l'API (déjà correcte pour setup nginx)
# Sur VPS avec nginx : laisser /api/v1
# Accès direct (sans nginx) : http://VPS_IP:3001/api/v1
NEXT_PUBLIC_API_URL=/api/v1

# WebSocket (laisser vide si nginx gère les WS)
NEXT_PUBLIC_WS_URL=

# Mapbox (optionnel — pour les cartes)
MAPBOX_TOKEN=

# AWS S3 (optionnel — pour les documents chauffeurs)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=taxivanille
S3_REGION=

# Firebase Cloud Messaging (optionnel — notifications push Android)
FCM_SERVER_KEY=

# CORS — origines autorisées par le backend
# Sur VPS avec nginx, laisser la valeur par défaut
ALLOWED_ORIGINS=http://localhost:80

# Environnement
NODE_ENV=production
